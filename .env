# Earth-Quake Environment Variables
# Copy this file to .env.local and fill in values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Earth-Quake"

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/earthquake?sslmode=require"

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="your-secret-key-here"

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token"

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Stripe (for future billing)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@earthquake.in"
